# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=cambia-esto-en-produccion-por-favor
JWT_EXPIRES_IN=7d

# PostgreSQL
DATABASE_URL=postgresql://libroclaro:libroclaro@localhost:5432/libroclaro?schema=public

# MongoDB
MONGO_URL=mongodb://libroclaro:libroclaro@localhost:27017/libroclaro?authSource=admin

# Storage
STORAGE_DIR=./storage

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Rate limit de /auth/login (A07). Déjalo vacío/false en desarrollo y producción;
# ponlo en true SOLO para ejecutar la suite E2E de Cypress (muchos logins legítimos).
RATE_LIMIT_DISABLED=false

# Azure Application Insights (opcional en desarrollo)
APPINSIGHTS_CONNECTION_STRING= 
