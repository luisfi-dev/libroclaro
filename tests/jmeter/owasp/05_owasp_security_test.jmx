        </hashTree>

        <!-- TC-A03-03: NoSQL Injection en búsqueda → no debe crashear -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="TC-A03-03: NoSQL operator injection en query → espera 200, no 500" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
