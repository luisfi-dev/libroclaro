                <stringProp name="Argument.value">{"fullName":"Menor Test","email":"menor@test.com","password":"test1234","confirmPassword":"test1234","birthDate":"2015-06-01"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/auth/register</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
