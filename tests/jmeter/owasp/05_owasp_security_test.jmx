                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <!-- PASS si responde 401 (no debe devolver 200 ni bloquearse con 500) -->
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="PASS si responde 401 (sin lockout inesperado)" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="52987">401</stringProp>
                <stringProp name="52980">400</stringProp>
                <stringProp name="52993">429</stringProp>
