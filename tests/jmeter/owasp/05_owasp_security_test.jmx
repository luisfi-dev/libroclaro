            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- TC-A07-04: Fuerza bruta — 10 intentos con credenciales incorrectas -->
        <LoopController guiclass="LoopControlGui" testclass="LoopController" testname="TC-A07-04: 10 intentos login incorrectos (fuerza bruta)" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">10</intProp>
        </LoopController>
        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Login con credenciales incorrectas" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
