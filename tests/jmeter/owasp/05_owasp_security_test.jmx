      <!-- ═══════════════════════════════════════════════════════════
           A05 — SECURITY MISCONFIGURATION
           Verificar headers de seguridad y mensajes de error.
      ═══════════════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="A05 — Security Misconfiguration" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
